# Database — Railway zet DATABASE_URL automatisch via service-link.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/dso

# Per-request statement timeout (ms). Voorkomt dat één query de pool leegtrekt.
OCD_STATEMENT_TIMEOUT_MS=10000

# Auth — twee-keys-strategie:
# - PUBLIC: in viewer-HTML, invalideerbaar bij scraper-misbruik
# - PRIVATE: voor backend-clients (Omgevingsbot etc.), nooit in browser
# - OCD_API_KEY (legacy): blijft werken als beide nieuwe leeg zijn
OCD_API_KEY=
OCD_API_KEY_PUBLIC=
OCD_API_KEY_PRIVATE=

# Fail-closed: container weigert te starten als true en er zijn geen keys.
# Lokaal/test: false. Productie: true.
OCD_REQUIRE_AUTH=false

# Swagger / OpenAPI — uit zetten in productie als je niet wilt dat het schema
# publiek is. /openapi.json kan apart uit met OCD_ENABLE_OPENAPI=false.
OCD_ENABLE_DOCS=true
OCD_ENABLE_OPENAPI=true

# Rate limit per client-IP (slowapi-syntax). Default 120/min is genoeg voor
# normale viewer-gebruik; bij scraper-druk lager zetten.
OCD_RATE_DEFAULT=120/minute

# Logging
OCD_LOG_LEVEL=INFO

# Server-poort (Railway zet automatisch PORT).
PORT=8001
